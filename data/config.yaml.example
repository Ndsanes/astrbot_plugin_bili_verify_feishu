# 说明:
# 1) 本插件现已按 AstrBot 官方规范使用 _conf_schema.json 定义配置。
# 2) 实际生效配置由 AstrBot 根据 Schema 自动生成并托管，不再从本文件读取。
# 3) 本文件仅作为字段示例，便于你在 WebUI 中填写。

FEISHU_APP_ID: "cli_xxxxxxxxxxxx"
FEISHU_APP_SECRET: "xxxxxxxxxxxxxxxxxxxxxxxx"
FEISHU_APP_TOKEN: "appxxxxxxxxxxxxxxxx"
FEISHU_TABLE_ID: "tblxxxxxxxxxxxx"
FEISHU_STATUS_FIELD: "状态"
FEISHU_STATUS_ACTIVE_VALUE: "在群"
FEISHU_STATUS_LEFT_VALUE: "已退群"

WHITELIST_GROUPS:
  - "123456789"
  - "987654321"

MAX_RETRIES: 3
RETRY_DELAY: 1.0
ENABLE_PENDING_CHECK: true
ENABLE_STARTUP_REQUEST_SCAN: true
STARTUP_REQUEST_SCAN_LIMIT: 50
PENDING_CHECK_INTERVAL: 60
